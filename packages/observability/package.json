{
  "name": "@agent-detective/observability",
  "version": "0.1.0",
  "type": "module",
  "description": "Observability infrastructure for agent-detective",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./logger": {
      "import": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./metrics": {
      "import": "./dist/metrics.js",
      "types": "./dist/metrics.d.ts"
    },
    "./tracing": {
      "import": "./dist/tracing.js",
      "types": "./dist/tracing.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.js",
      "types": "./dist/middleware.d.ts"
    },
    "./health": {
      "import": "./dist/health.js",
      "types": "./dist/health.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "fastify": "^5.8.5"
  }
}
