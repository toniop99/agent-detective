{
  "name": "@agent-detective/core",
  "version": "0.1.0",
  "description": "Core utilities and decorators for agent-detective",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsx --test",
    "clean": "rm -rf dist"
  },
  "keywords": ["agent-detective", "core", "decorators"],
  "license": "MIT",
  "dependencies": {
    "@agent-detective/types": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
