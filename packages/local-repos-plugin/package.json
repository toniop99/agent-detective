{
  "name": "@agent-detective/local-repos-plugin",
  "version": "0.1.0",
  "description": "Local repository access plugin for agent-detective",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsx --test",
    "clean": "rm -rf dist"
  },
  "keywords": ["agent-detective", "repository", "local"],
  "license": "MIT",
  "dependencies": {
    "@agent-detective/core": "workspace:*",
    "@agent-detective/process-utils": "workspace:*",
    "@agent-detective/types": "workspace:*",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}