{
  "name": "@agent-detective/local-repos-plugin",
  "version": "0.1.0",
  "description": "Local repository access plugin for agent-detective",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"test/**/*.test.ts\"",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agent-detective",
    "repository",
    "local"
  ],
  "license": "MIT",
  "dependencies": {
    "@agent-detective/process-utils": "workspace:*",
    "@agent-detective/sdk": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toniop99/agent-detective.git"
  },
  "author": "Antonio Hernandez",
  "bugs": {
    "url": "https://github.com/toniop99/agent-detective/issues"
  }
}
