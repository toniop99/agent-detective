{
  "name": "@agent-detective/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for agent-detective core and plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "keywords": ["agent-detective", "types"],
  "license": "MIT"
}
