{
  "name": "@agent-detective/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for agent-detective core and plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "keywords": [
    "agent-detective",
    "types"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toniop99/agent-detective.git"
  },
  "author": "Antonio Hernandez",
  "bugs": {
    "url": "https://github.com/toniop99/agent-detective/issues"
  }
}
