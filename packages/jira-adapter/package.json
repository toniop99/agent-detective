{
  "name": "@agent-detective/jira-adapter",
  "version": "0.1.0",
  "description": "Jira webhook adapter for agent-detective",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"test/**/*.test.ts\"",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "agent-detective",
    "jira",
    "adapter"
  ],
  "license": "MIT",
  "dependencies": {
    "@agent-detective/core": "workspace:*",
    "@agent-detective/local-repos-plugin": "workspace:*",
    "@agent-detective/types": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
