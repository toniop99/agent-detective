# Auto-detect text files
* text=auto

# Source files
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.yaml text
*.yml text
*.md text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Git files
.gitattributes export-ignore
.gitignore export-ignore

# Documentation
README.md text
CHANGELOG.md text
LICENSE text

# Config
*.example text
schema.json text
