# .gitignore

# Turborepo
.turbo/
*.tsbuildinfo

# Changesets (keep README)
.changeset/
!.changeset/README.md

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dist-sea/
packages/types/dist/
packages/jira-adapter/dist/

# Build artifacts
*.js.map
*.d.ts.map
*.d.ts

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo

# Test
coverage/

# Lock files
package-lock.json
# pnpm-lock.yaml is required for reproducible installs (CI and production builds)
!pnpm-lock.yaml

# Temporary
tmp/
temp/
*.tmp
plans
deploy/

# Local config (overrides default.json)
config/local.json

# Agent plans (local); shared prompts live in .agents/agents and .agents/skills
.agents/plans/

# Generated from .agents/ for Cursor (symlinks or dirs; trailing slash alone can miss symlinks)
.cursor/agents
.cursor/skills