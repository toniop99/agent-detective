---
import type { LandingStrings } from '../i18n/strings';

interface Props {
  flow: LandingStrings['flow'];
}

const { flow } = Astro.props;
const steps = flow.steps.map((text, idx) => ({ step: idx + 1, text }));
---

<section
  id="docket"
  data-section="docket"
  class="ad-reveal mt-20 scroll-mt-28 sm:mt-28"
  aria-labelledby="flow-heading"
>
  <div
    class="lg:grid lg:grid-cols-12 lg:items-start lg:gap-10"
  >
    <div
      class="lg:col-span-5"
    >
      <h2
        id="flow-heading"
        class="ad-section-label"
      >{flow.sectionLabel}</h2
      >
      <p
        class="text-paper-50 font-display mt-2 text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {flow.title}
      </p>
      <p
        class="text-paper-200/80 mt-4 text-base leading-relaxed"
        set:html={flow.introHtml}
      />
    </div>
    <div
      class="mt-8 lg:col-span-7 lg:mt-0"
    >
      <ol
        class="border-paper-200/20 space-y-4 border-l-2 pl-7 sm:pl-8"
        role="list"
      >
        {
          steps.map((row) => (
            <li
              class="bg-ink-800/20 border-paper-200/6 relative border p-4 pl-5 sm:pl-6"
            >
              <span
                class="border-ink-1000 from-ink-800 text-amber-400/95 font-mono text-[0.7rem] font-bold bg-linear-to-b absolute top-5 left-[-2.1rem] z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 to-ink-900 shadow-[0_0_0_2px_#050506,0_0_20px_rgba(232,168,73,0.08)]"
              >
                {row.step}
              </span>
              <span
                class="text-paper-200/90 text-sm leading-relaxed sm:text-[0.95rem] sm:leading-7"
              >{row.text}
              </span>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
