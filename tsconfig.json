{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@agent-detective/types": ["./packages/types/src/index.ts"],
      "@agent-detective/observability": ["./packages/observability/src/index.ts"],
      "@agent-detective/local-repos-plugin": ["./packages/local-repos-plugin/src/index.ts"],
      "@agent-detective/jira-adapter": ["./packages/jira-adapter/src/index.ts"],
      "@agent-detective/process-utils": ["./packages/process-utils/src/index.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*", "packages/*/src/**/*"],
  "exclude": ["node_modules", "dist", "packages/*/dist", "packages/*/node_modules"]
}